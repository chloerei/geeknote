<% @show_dock = true %>

<div class="navbar px-0 gap-4">
  <div class="flex-none">
    <label for="drawer" class="btn btn-square btn-ghost lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu-icon lucide-menu"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>
    </label>
  </div>
  <div class="grow">
    <div class="text-xl font-medium">
      <%= t "general.overview" %>
    </div>
  </div>
  <div class="flex-none">
    <a href="<%= new_dashboard_post_path(@account.name) %>" class="btn btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      <%= t "general.new_post" %>
    </a>
  </div>
</div>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="stat bg-base-100 rounded-box p-4 border border-base-300">
    <div class="stat-figure text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
    </div>
    <div class="stat-title"><%= t "general.posts" %></div>
    <div class="stat-value"><%= @posts_published.count %></div>
    <div class="stat-desc">
      <%= @posts_draft.count %> <%= t "general.draft" %>
    </div>
  </div>

  <div class="stat bg-base-100 rounded-box p-4 border border-base-300">
    <div class="stat-figure text-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye-icon lucide-eye"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
    </div>
    <div class="stat-title"><%= t "general.views" %></div>
    <div class="stat-value"><%= number_with_delimiter @total_views %></div>
    <div class="stat-desc">
      <%= number_with_delimiter @total_comments %> <%= t "general.comments" %>
    </div>
  </div>

  <div class="stat bg-base-100 rounded-box p-4 border border-base-300">
    <div class="stat-figure text-error">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-icon lucide-heart"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
    </div>
    <div class="stat-title"><%= t "general.likes" %></div>
    <div class="stat-value"><%= number_with_delimiter @total_likes %></div>
    <div class="stat-desc">
      <%= number_with_delimiter @total_bookmarks %> <%= t "general.bookmarks" %>
    </div>
  </div>

  <div class="stat bg-base-100 rounded-box p-4 border border-base-300">
    <div class="stat-figure text-info">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users-icon lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="stat-title"><%= t "general.followers" %></div>
    <div class="stat-value"><%= @account.followers_count %></div>
    <div class="stat-desc">&nbsp;</div>
  </div>
</div>

<div class="card card-default">
  <div class="card-body">
    <div class="flex items-center justify-between mb-4">
      <h2 class="card-title mb-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-icon lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <%= t "general.newest" %>
      </h2>
      <a href="<%= dashboard_posts_path(@account.name) %>" class="btn btn-ghost btn-sm">
        <%= t "general.view_all_posts" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right-icon lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <% if @recent_posts.any? %>
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th><%= t "general.title" %></th>
              <th class="text-center w-20"><%= t "general.likes" %></th>
              <th class="text-center w-20"><%= t "general.comments" %></th>
              <th class="text-right w-28"><%= t "general.created_at" %></th>
            </tr>
          </thead>
          <tbody>
            <% @recent_posts.each do |post| %>
              <tr class="hover">
                <td>
                  <a href="<%= edit_dashboard_post_path(@account.name, post) %>" class="line-clamp-1 hover:underline">
                    <%= post.title.presence || t("general.untitled") %>
                  </a>
                </td>
                <td class="text-center"><%= post.likes_count %></td>
                <td class="text-center"><%= post.comments_count %></td>
                <td class="text-right text-xs text-base-content/60 whitespace-nowrap">
                  <%= post.published_at.strftime("%Y-%m-%d") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="flex flex-col items-center gap-3 py-12 text-base-content/50">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        <p><%= t "general.no_more_content" %></p>
        <a href="<%= new_dashboard_post_path(@account.name) %>" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          <%= t "general.new_post" %>
        </a>
      </div>
    <% end %>
  </div>
</div>

<!-- 草稿箱 -->
<% if @recent_drafts.any? %>
  <div class="card card-default mt-4">
    <div class="card-body">
      <h2 class="card-title mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-icon lucide-pencil"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
        <%= t "general.draft" %>
      </h2>

      <div class="space-y-2">
        <% @recent_drafts.each do |post| %>
          <a href="<%= edit_dashboard_post_path(@account.name, post) %>" class="flex items-center justify-between p-3 rounded-lg hover:bg-base-200 transition-colors">
            <div class="flex items-center gap-3 min-w-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-icon lucide-file shrink-0 text-base-content/40"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
              <span class="line-clamp-1"><%= post.title.presence || t("general.untitled") %></span>
            </div>
            <span class="text-xs text-base-content/50 shrink-0 ml-2 whitespace-nowrap">
              <%= post.updated_at.strftime("%Y-%m-%d") %>
            </span>
          </a>
        <% end %>
      </div>

      <div class="mt-3 text-center">
        <a href="<%= dashboard_posts_path(@account.name, status: "draft") %>" class="btn btn-ghost btn-sm">
          <%= t "general.view_all_posts" %>
        </a>
      </div>
    </div>
  </div>
<% end %>
