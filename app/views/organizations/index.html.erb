<% @page_titles.prepend t("general.organizations") %>

<div class="max-w-screen-sm mx-auto">
  <div class="card">
    <div class="flex items-center h-14 p-2">
      <a href="<%= root_path %>" class="icon-button">
        <x-icon>arrow_back</x-icon>
      </a>
      <div class="flex-grow px-2 text-lg font-medium">
        <%= t "general.organizations" %>
      </div>
      <a href="<%= new_organization_path %>" class="btn btn-primary btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        <%= t "general.new" %>
      </a>
    </div>

    <% if @organizations.any? %>
      <div class="divide-y divide-base-300">
        <% @organizations.each do |organization| %>
          <div class="flex items-center gap-4 p-4">
            <div class="avatar">
              <div class="size-12 rounded-full">
                <img src="<%= avatar_url(organization) %>" alt="<%= organization.name %>">
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-medium truncate">
                <%= organization.name %>
              </div>
              <div class="text-sm text-base-content/60">
                @<%= organization.account.name %>
              </div>
              <div class="text-sm text-base-content/50">
                <span class="badge badge-sm">
                  <%= Member.human_attribute_name("role.#{Member.roles.key(organization.member_role.to_i)}") %>
                </span>
              </div>
            </div>
            <a href="<%= dashboard_root_path(organization.account.name) %>" class="btn btn-ghost btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-dashboard-icon lucide-layout-dashboard"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
              <%= t "general.dashboard" %>
            </a>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col items-center gap-3 py-16 text-base-content/50">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-building-2-icon lucide-building-2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
        <div class="text-lg font-medium">
          <%= t ".no_organizations" %>
        </div>
        <p class="text-sm text-center">
          <%= t ".no_organizations_description" %>
        </p>
        <a href="<%= new_organization_path %>" class="btn btn-primary mt-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          <%= t ".create_organization" %>
        </a>
      </div>
    <% end %>
  </div>
</div>
