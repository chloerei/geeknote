<div class="max-w-screen-sm mx-auto">
  <div class="navbar px-0 gap-4">
    <div class="flex-none">
      <a href="<%= organizations_path %>" class="btn btn-square btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      </a>
    </div>
    <div class="grow">
      <div class="text-xl font-medium">
        <%= t ".title" %>
      </div>
    </div>
  </div>

  <div class="card card-default">
    <div class="card-body">
      <%= form_with model: @organization do |form| %>
        <%= form.fields_for :account do |account_form| %>
          <%= render "components/text_field", form: account_form, name: :name, prefix: Rails.application.config.x.host + "/" %>
        <% end %>
        <%= render "components/text_field", form: form, name: :name %>
        <div class="mt-4">
          <button type="submit" class="btn btn-primary">
            <%= t ".submit" %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
