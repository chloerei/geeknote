<div class="drawer-side">
  <label for="drawer" class="drawer-overlay"></label>

  <div class="flex flex-col w-60 h-full bg-base-200 border-r border-base-300">
    <div class="navbar px-4 py-3 border-b border-base-300">
      <div class="dropdown w-full">
        <label tabindex="0" class="btn btn-ghost btn-block justify-start gap-3 px-3">
          <div class="avatar">
            <div class="size-5 rounded-full">
              <img src="<%= avatar_url(@account.owner) %>" alt="avatar">
            </div>
          </div>
          <div class="flex-1 text-left text-sm font-medium truncate">
            <%= @account.owner.name %>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg>
        </label>
        <ul class="dropdown-content menu bg-base-100 w-52 shadow-sm">
          <% ([Current.user.account] + Current.user.member_accounts).each do |account| %>
            <li>
              <a href="<%= dashboard_root_path(account.name) %>" class="<%= "menu-active" if account == @account %>">
                <div class="avatar">
                  <div class="size-5 rounded-full">
                    <img src="<%= avatar_url(account.owner) %>" alt="avatar">
                  </div>
                </div>
                <span><%= account.owner.name %></span>
              </a>
            </li>
          <% end %>
          <li></li>
          <li>
            <a href="/organizations">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-building-2-icon lucide-building-2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
              <%= t "general.my_organizations" %>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="grow overflow-auto">
      <ul class="menu w-full p-3 gap-1">
        <li>
          <a href="<%= root_path %>" class="px-4 py-2 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            <%= t "general.back_to_home" %>
          </a>
        </li>
        <li></li>
        <li>
          <a href="<%= dashboard_root_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if current_page?(dashboard_root_path(@account.name)) %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-dashboard-icon lucide-layout-dashboard"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
            <%= t "general.overview" %>
          </a>
        </li>
        <li>
          <a href="<%= dashboard_posts_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if current_page?(dashboard_posts_path(@account.name)) %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            <%= t "general.posts" %>
          </a>
        </li>
        <li>
          <a href="<%= dashboard_series_index_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if controller_name == "series" %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-text-icon lucide-book-text"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/><path d="M8 11h8"/><path d="M8 7h6"/></svg>
            <%= t "general.series" %>
          </a>
        </li>
        <li>
          <a href="<%= dashboard_analytics_root_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if request.path.start_with?(dashboard_analytics_root_path(@account.name)) %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chart-spline-icon lucide-chart-spline"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="M7 16c.5-2 1.5-7 4-7 2 0 2 3 4 3 2.5 0 4.5-5 5-7"/></svg>
            <%= t "general.analytics" %>
          </a>
        </li>
        <% if @account.can_manage_by?(Current.user) %>
          <li></li>
          <li>
            <a href="<%= dashboard_settings_profile_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if controller_name == "profiles" %>">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-user-icon lucide-square-user"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="12" cy="10" r="3"/><path d="M7 21v-2a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/></svg>
              <%= t "general.profile" %>
            </a>
          </li>
          <% if @account.organization? %>
            <li>
              <a href="<%= dashboard_settings_members_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if controller_name == "members" %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users-icon lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="9" cy="7" r="4"/></svg>
                <%= t "general.members" %>
              </a>
            </li>
          <% end %>
          <li>
            <a href="<%= dashboard_settings_export_path(@account.name) %>" class="px-4 py-2 rounded-full <%= "menu-active" if controller_name == "exports" %>">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-down-icon lucide-folder-down"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/><path d="M12 10v6"/><path d="m15 13-3 3-3-3"/></svg>
              <%= t "general.export" %>
            </a>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="p-3 border-t border-base-300">
      <% if Current.user %>
        <div class="dropdown dropdown-top w-full">
          <label tabindex="0" class="btn btn-ghost btn-block justify-start gap-3 px-3">
            <div class="avatar">
              <div class="size-9 rounded-full">
                <img src="<%= avatar_url(Current.user) %>">
              </div>
            </div>
            <div class="flex-1 text-left">
              <div class="font-medium text-sm"><%= Current.user.account.name %></div>
              <div class="text-xs text-base-content/50">@<%= Current.user.name %></div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-up-icon lucide-chevron-up"><path d="m18 15-6-6-6 6"/></svg>
          </label>
          <ul tabindex="0" class="dropdown-content menu w-full bg-base-200 rounded-xl shadow-lg border border-base-300 p-2">
            <li>
              <a href="<%= settings_root_path %>">
                <%= t "general.settings" %>
              </a>
            </li>
            <li></li>
            <li>
              <a href="<%= session_path %>" data-turbo-method="delete">
                <%= t "general.sign_out" %>
              </a>
            </li>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</div>
