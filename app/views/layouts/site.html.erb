<% content_for :content do %>
  <div class="drawer lg:drawer-open">
    <input type="checkbox" class="drawer-toggle" id="drawer">

    <%= render "layouts/site/drawer_side" %>

    <div class="drawer-content pb-16 lg:pb-0">
      <%= raw @site.site_header_html %>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 pb-6">
        <%= yield %>
      </div>

      <%= raw @site.site_footer_html %>
    </div>
  </div>

  <% if @show_dock %>
    <%= render "layouts/site/dock" %>
  <% end %>
<% end %>

<%= render template: "layouts/application" %>
