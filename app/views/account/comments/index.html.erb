<div class="navbar px-0 gap-4">
  <div class="flex-none">
    <a href="<%= root_path %>" class="btn btn-square btn-ghost" data-controller="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ar
ow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <div class="grow">
    <div class="text-xl font-medium">
      <%= @account.owner.name %>
    </div>
  </div>
</div>

<div class="layout-main-sidebar">
  <div>
    <%= render "account/profile_card", account: @account %>

    <div class="mt-4">
      <%= render "account/tabs", active_tab: "comments" %>
    </div>

    <div class="mt-4">
      <%= render "components/scroll_pagination", pagy: @pagy, content_class: "space-y-4" do %>
        <%= render partial: "account/comments/comment_item", collection: @comments, as: :comment, cached: -> comment { [ comment.user, comment ] } %>
      <% end %>
    </div>
  </div>

  <%= render "account/sidebar" %>
</div>
