<section id="<%= dom_id(post) %>" class="card card-default overflow-hidden hover:shadow-xs">
  <div class="card-body p-4 sm:p-5">
    <div class="flex flex-row gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="text-base sm:text-lg font-semibold hover:text-primary transition-colors line-clamp-2">
              <a href="<%= account_post_path(post.account.name, post) %>" class="after:absolute after:inset-0">
                <%= post.title.presence || t("general.untitled") %>
              </a>
            </h3>
            <p class="text-sm text-base-content/60 mt-2 line-clamp-2">
              <%= markdown_summary post.content %>
            </p>
          </div>
        </div>

        <% if post.tags.any? %>
          <div class="flex flex-wrap gap-2 mt-4">
            <% post.tags.each do |tag| %>
              <span class="badge badge-ghost badge-sm"># <%= tag.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if post.featured_image.attached? %>
        <figure class="w-32 sm:w-40 shrink-0 self-start aspect-video">
          <%= image_tag post.featured_image.variant(:large), alt: "Featured image", class: "w-full h-full object-cover rounded-box" %>
        </figure>
      <% end %>
    </div>

    <!-- Author & Meta Row -->
    <div class="flex items-center justify-between mt-3 pt-3 border-t border-base-300/50">
      <div class="flex items-center gap-2.5 min-w-0">
        <div class="avatar">
          <div class="size-6 rounded-full">
            <%= image_tag avatar_url(post.user), alt: "Avatar" %>
          </div>
        </div>
        <div class="min-w-0">
          <span class="text-sm font-medium"><%= post.user.name %></span>
          <% if post.account != post.user.account %>
            <span class="text-xs text-base-content/60">
              <%= t "general.in" %>
              <span><%= post.account.owner.name %></span>
            </span>
          <% end %>
        </div>
        <span class="text-xs text-base-content/60">·</span>
        <span class="text-xs text-base-content/60 whitespace-nowrap"><%= format_time post.published_at %></span>
      </div>

      <div class="flex items-center gap-3 text-base-content/60 shrink-0">
        <div class="flex items-center gap-1 hover:text-primary transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle-icon lucide-message-circle"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/></svg>
          <span class="text-xs tabular-nums"><%= post.comments_count %></span>
        </div>
        <div class="flex items-center gap-1 hover:text-error transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-icon lucide-heart"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
          <span class="text-xs tabular-nums"><%= post.likes_count %></span>
        </div>
      </div>
    </div>
  </div>
</section>
