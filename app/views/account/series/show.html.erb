<div class="navbar px-0 gap-4">
  <div class="flex-none">
    <a href="<%= account_series_index_path(@account.name) %>" class="btn btn-square btn-ghost">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  </div>
  <div class="grow">
    <div class="text-xl font-medium">
      <%= t "general.series" %>
    </div>
  </div>
</div>

<div class="layout-main-sidebar">
  <div class="min-w-0">
    <div class="card card-default">
      <div class="card-body">
        <h1 class="text-3xl font-medium">
          <%= @series.title %>
        </h1>

        <% if @series.description.present? %>
          <p class="mt-2 text-base-content/70">
            <%= @series.description %>
          </p>
        <% end %>

        <div class="flex gap-4 mt-4">
          <div class="shrink-0">
            <a href="<%= account_root_path(@account.name) %>">
              <%= image_tag avatar_url(@account.owner), alt: "avatar", class: "w-10 h-10 rounded-full" %>
            </a>
          </div>

          <div class="grow">
            <div class="text-sm">
              <a href="<%= account_root_path(@account.name) %>" class="font-medium">
                <%= @account.owner.name %>
              </a>
            </div>
            <div class="text-sm text-base-content/60">
              <%= @series.posts.published.count %> <%= t("general.posts") %>
              &centerdot;
              <%= format_time @series.updated_at %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if @posts.any? %>
      <div class="mt-4">
        <%= render "components/scroll_pagination", pagy: @pagy, content_html: { class: "space-y-4" } do %>
          <%= render partial: "account/posts/post", collection: @posts, as: :post %>
        <% end %>
      </div>
    <% else %>
      <div class="card card-default mt-4">
        <div class="card-body">
          <div class="flex flex-col items-center gap-3 py-12 text-base-content/50">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            <p class="text-sm"><%= t("dashboard.series.show.empty") %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <%= raw @site.sidebar_header_html %>

    <div class="card card-default">
      <div class="card-body">
        <div class="list -m-4">
          <%= render "account/item", account: @account %>
        </div>
      </div>
    </div>

    <%= raw @site.sidebar_footer_html %>
  </div>
</div>
