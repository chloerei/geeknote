<%# locals: (account:) %>

<div class="list-row hover:bg-base-200/50">
  <div class="avatar">
    <div class="size-10 rounded-full">
      <%= image_tag avatar_url(account.owner), alt: "Avatar" %>
    </div>
  </div>
  <div>
    <div class="text-sm font-medium">
      <a href="<%= account_root_path(account.name) %>" class="after:absolute after:inset-0">
        <%= account.owner.name %>
      </a>
    </div>
    <div class="text-sm text-base-content/60">
      @<%= account.name %>
    </div>
  </div>
  <% if account.description.present? %>
    <div class="list-col-wrap text-sm text-base-content/80 line-clamp-2">
      <%= account.description %>
    </div>
  <% end %>
  <% if account != Current.user&.account %>
    <div class="relative">
      <%= render "account/follows/button", account: account %>
    </div>
  <% end %>
</div>
